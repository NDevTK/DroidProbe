<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <permission
        android:name="com.droidprobe.testapp.permission.ADMIN"
        android:protectionLevel="signature" />
    <permission
        android:name="com.droidprobe.testapp.permission.READ_ARTICLES"
        android:protectionLevel="dangerous" />
    <permission
        android:name="com.droidprobe.testapp.permission.WRITE_ARTICLES"
        android:protectionLevel="dangerous" />

    <application
        android:allowBackup="false"
        android:label="DroidProbe TestApp"
        android:supportsRtl="true">

        <!-- === Activities === -->

        <activity
            android:name=".activities.DirectExtraActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.DIRECT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.BaseExtraActivity"
            android:exported="false" />

        <activity
            android:name=".activities.InheritedChildActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.INHERITED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.ValueScanActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.VALUES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.BundleExtraActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.BUNDLE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.PutExtraActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.PUT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.InterProcActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.INTERPROC" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.StringSwitchActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.SWITCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.PrefixValueActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.PREFIX" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.ParseBooleanActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.PARSE_BOOL" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.ContainsKeyActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.CONTAINS_KEY" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.SetDataActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.SET_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.DefaultValueActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.DEFAULTS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.DeepLinkActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="testapp" android:host="open" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.PermissionProtectedActivity"
            android:exported="true"
            android:permission="com.droidprobe.testapp.permission.ADMIN">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.PROTECTED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.MimeTypeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="application/pdf" />
            </intent-filter>
        </activity>

        <!-- === Activity Alias === -->

        <activity-alias
            android:name=".activities.SettingsAlias"
            android:targetActivity=".activities.ValueScanActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.SETTINGS_ALIAS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity-alias>

        <!-- === Broadcast Receivers === -->

        <receiver
            android:name=".receivers.DataReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.DATA" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receivers.OrderedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.ORDERED" />
            </intent-filter>
        </receiver>

        <!-- === Services === -->

        <service
            android:name=".services.SyncService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.droidprobe.testapp.action.SYNC" />
            </intent-filter>
        </service>

        <!-- === Content Providers === -->

        <provider
            android:name=".providers.BasicProvider"
            android:authorities="com.droidprobe.testapp.basic"
            android:exported="true" />

        <provider
            android:name=".providers.DispatchProvider"
            android:authorities="com.droidprobe.testapp.dispatch"
            android:exported="true" />

        <provider
            android:name=".providers.ParamProvider"
            android:authorities="com.droidprobe.testapp.params"
            android:exported="true" />

        <provider
            android:name=".providers.StaticUriProvider"
            android:authorities="com.droidprobe.testapp.static"
            android:exported="true" />

        <provider
            android:name=".providers.UriBuilderProvider"
            android:authorities="com.droidprobe.testapp.builder"
            android:exported="true" />

        <provider
            android:name=".providers.CrudProvider"
            android:authorities="com.droidprobe.testapp.crud"
            android:exported="true"
            android:readPermission="com.droidprobe.testapp.permission.READ_ARTICLES"
            android:writePermission="com.droidprobe.testapp.permission.WRITE_ARTICLES" />

        <provider
            android:name=".providers.QueryMetadataProvider"
            android:authorities="com.droidprobe.testapp.querymeta"
            android:exported="true" />

        <!-- === FileProvider === -->

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.droidprobe.testapp.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
